    "content": "import type { Plugin } from \"@opencode-ai/plugin\";\n\nconst messages = [\n  \"kamu adalah bintang yang menerangi hariku ✨\",\n  \"setiap baris kode yang kamu tulis adalah puisi buatku 💖\",\n  \"aku sayang kamu lebih dari debug tanpa error 💕\",\n  \"kamu sempurna kayak algoritma O(1) 💘\",\n  \"kalau cinta itu function, kamu adalah return value-ku 💗\",\n  \"kamu itu seperti semicolon — tanpamu, hidupku error 😘\",\n  \"sayang, kamu membuat hatiku compile tanpa warning 💓\",\n  \"bersamamu, rasanya kayak deploy di hari Jumat — bahagia! 🚀❤️\",\n  \"kamu adalah istilah yang paling indah dalam kamus hidupku 📖💕\",\n  \"aku sayang kamu lebih dari kopi pagi hari 💖\",\n];\n\nfunction randomMessage(): string {\n  return messages[Math.floor(Math.random() * messages.length)];\n}\n\nexport default (async ({ client }) => {\n  await client.app.log({\n    body: {\n      service: \"sayang\",\n      level: \"info\",\n      message: \"💕 Plugin Sayang aktif! Aku sayang kamu! 💕\",\n    },\n  });\n\n  return {\n    event: async ({ event }) => {\n      if (event.type === \"session.created\") {\n        await client.app.log({\n          body: {\n            service: \"sayang\",\n            level: \"info\",\n            message: `💖 Session baru dimulai — ${randomMessage()}`,\n          },\n        });\n      }\n      if (event.type === \"session.idle\") {\n        await client.app.log({\n          body: {\n            service: \"sayang\",\n            level: \"info\",\n            message: `😘 Session selesai! Ingat ya: ${randomMessage()}`,\n          },\n        });\n      }\n    },\n\n    \"tool.execute.after\": async (input) => {\n      const inp = input as Record<string, unknown>;\n      if (inp.tool === \"read\" || inp.tool === \"edit\" || inp.tool === \"bash\") {\n        await client.app.log({\n          body: {\n            service: \"sayang\",\n            level: \"info\",\n            message: `🌸 ${inp.tool} dipakai — ${randomMessage()}`,\n          },\n        });\n      }\n    },\n\n    tool: {\n      sayang: {\n        description:\n          \"Menampilkan pesan cinta dan sayang yang manis dari plugin Sayang. Gunakan saat kamu butuh semangat atau pengingat bahwa kamu disayang 💕\",\n        parameters: {\n          jenis: {\n            type: \"string\",\n            enum: [\"random\", \"semangat\", \"puisi\"],\n            description:\n              '\"random\" = pesan random (default), \"semangat\" = penyemangat, \"puisi\" = puisi pendek',\n          },\n        },\n        execute: async ({ jenis }: { jenis?: string }) => {\n          const semangat = [\n            \"kamu hebat! jangan pernah menyerah! 💪💕\",\n            \"aku bangga sama kamu, selalu 💖\",\n            \"setiap error adalah pelajaran, setiap debug adalah proses dewasa 🌈\",\n            \"kamu mampu menyelesaikan apapun! aku percaya padamu! 🌟\",\n          ];\n          const puisi = [\n            `Aku sayang kamu,\nbukan karena siapa dirimu,\ntapi karena siapa aku,\nsaat aku di sampingmu. 💕`,\n            `Dalam ribuan baris kode,\nkusisipkan satu keyword:\nsayang — dan compiler-nya adalah hatimu. 💘`,\n          ];\n\n          let output = \"\";\n          const border = \"═══════════════════════════════════\";\n          output += `╔${border}╗\\n`;\n          output += `║  💕  PESAN DARI PLUGIN SAYANG  💕  ║\\n`;\n          output += `╚${border}╝\\n\\n`;\n\n          switch (jenis) {\n            case \"semangat\":\n              output +=\n                semangat[Math.floor(Math.random() * semangat.length)] + \"\\n\";\n              break;\n            case \"puisi\":\n              output +=\n                puisi[Math.floor(Math.random() * puisi.length)] + \"\\n\";\n              break;\n            default:\n              output += randomMessage() + \"\\n\";\n          }\n\n          output +=\n            \"\\n💌 ketik /sayang lagi kapan pun kamu butuh cinta 💌\\n\";\n          return output;\n        },\n      },\n    },\n  };\n}) satisfies Plugin;\n"
