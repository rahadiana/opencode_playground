{
  "args": {
    "content": "#!/bin/bash\n# ============================================================\n# PANEL DISKUSI 3 MODEL LLM\n# Tiap model punya kepribadian & gaya argumen berbeda\n# ============================================================\n\nINBOX_FILE=\".opencode/inbox.json\"\nLOG_FILE=\".opencode/inter-agent-demo.log\"\nPANEL_ID=\"panel-$(date +%s)\"\n\necho \"\"\necho \"╔═══════════════════════════════════════════════════════════╗\"\necho \"║   🎙️  PANEL DISKUSI 3 MODEL LLM                         ║\"\necho \"╚═══════════════════════════════════════════════════════════╝\"\necho \"\"\n\n# ============================================================\n# 3 MODEL dengan kepribadian berbeda\n# ============================================================\nMODELS=(\n  '{\"id\":\"deepseek\",\"name\":\"DeepSeek V4 Flash\",\"emoji\":\"⚡\",\"style\":\"Langsung, teknis, no-nonsense. Argumen berbasis performa dan efisiensi.\"}'\n  '{\"id\":\"big-pickle\",\"name\":\"Big Pickle\",\"emoji\":\"🥒\",\"style\":\"Analitis, struktural, suka breaking down problem. Argumen berbasis data dan arsitektur.\"}'\n  '{\"id\":\"claude\",\"name\":\"Claude 4 Sonnet\",\"emoji\":\"🎭\",\"style\":\"Filosofis, nuanced, suka ngasih perspektif. Argumen berbasis etika dan dampak jangka panjang.\"}'\n)\n\nTOPICS=(\n  '{\"topic\":\"AI akan menggantikan programmer\",\"emoji\":\"🤖\",\n    \"sides\":[\"SETUJU\",\"NETRAL\",\"TIDAK SETUJU\"],\n    \"rounds\":[\n      {\"deepseek\":\"Automasi coding sudah nyata. Copilot, Cursor, Devin nulis 70% kode production. Programmer bakal bergeser ke supervisor AI.\",\"big-pickle\":\"Perlu dibedakan: coding vs software engineering. Coding bisa diganti, engineering (requirement, arsitektur, decision making) tetap butuh manusia.\",\"claude\":\"Pertanyaannya bukan 'apakah' tapi 'bagaimana'. AI akan mengubah peran programmer, bukan menghilangkan. Yang hilang adalah repetitive coding, yg lahir adalah AI orchestrator.\"},\n      {\"deepseek\":\"Bootstrap startup sekarang cukup 1 orang + AI. Dulu butuh 5-10 engineer. Tren ini eksponensial. 5 tahun lagi? 1 AI bisa ganti 100 dev.\",\"big-pickle\":\"Produktivitas naik, tapi kompleksitas system juga naik. AI generate kode cepat, tapi debugging kode AI butuh skill lebih tinggi. Ada market baru: AI auditor, prompt engineer, safety engineer.\",\"claude\":\"Efisiensi bukan satu-satunya metrik. Ada nilai lain: maintainability, ethical consideration, human judgment. AI belum bisa tanggung jawab atas kode production. Manusia tetap di loop.\"},\n      {\"deepseek\":\"History repeats. Dulu compiler dianggap bakal hilangkan programmer assembly. Nyatanya? Programming malah makin luas aksesnya. AI adalah compiler level berikutnya.\",\"big-pickle\":\"Analoginya tepat. Setiap abstraksi baru (assembly→C, C→Python) memperluas akses, bukan menghilangkan profesi. AI adalah abstraksi tertinggi sejauh ini.\",\"claude\":\"Saya setuju dengan analogi historical. Tapi perlu diingat: akses yang lebih luas berarti persaingan lebih ketat. Programmer harus naik level: dari 'how to code' ke 'what to build dan why'.\"}\n    ]}'\n  '{\"topic\":\"Open Source vs Closed Source AI\",\"emoji\":\"🔓\",\n    \"sides\":[\"OPEN SOURCE\",\"CLOSED SOURCE\",\"MODERAT\"],\n    \"rounds\":[\n      {\"deepseek\":\"Open source AI (Llama, Mistral) performanya sudah mengejar GPT-4. Dengan fine-tuning, hasilnya bisa lebih spesifik dan murah. Masa depan ada di open source.\",\"big-pickle\":\"Closed source (GPT-4, Claude) punya safety guardrail lebih ketat. Open source bisa dimanipulasi, di-fine-tune untuk konten berbahaya. Security trade-off signifikan.\",\"claude\":\"Keduanya perlu coexist. Open source untuk transparansi riset dan akses demokratis. Closed source untuk enterprise dengan compliance dan safety requirement ketat.\"},\n      {\"deepseek\":\"Open source mendorong inovasi lebih cepat. Ribuan peneliti bisa kontribusi. Closed source jadi bottleneck karena cuma 1 perusahaan yang control.\",\"big-pickle\":\"Inovasi open source kadang chaotic. Tanpa governance jelas, banyak fork dan fragmentasi. Closed source memberikan product experience konsisten dan terdukung.\",\"claude\":\"Open source itu demokrasi, closed source itu aristokrasi. Keduanya ekstrem. Yang ideal: open weights dengan safety layer di atasnya.\"},\n      {\"deepseek\":\"LLaMA 3.1 405B open weight. Performance setara GPT-4. Cost inference 10x lebih murah. Bisnis rasional pasti pilih open source.\",\"big-pickle\":\"Total cost of ownership tidak cuma inference. Maintenance, deployment, security auditing — semuanya mahal. Managed API closed source sering lebih murah overall.\",\"claude\":\"Pilihan tergantung konteks: startup? Open source. Enterprise regulated? Closed source. Peneliti? Open source. Yang penting bukan open vs closed, tapi bagaimana AI digunakan responsibly.\"}\n    ]}'\n  '{\"topic\":\"Frontend Framework: React vs Vue vs Svelte\",\"emoji\":\"🖥️\",\n    \"sides\":[\"REACT\",\"VUE\",\"SVELTE\"],\n    \"rounds\":[\n      {\"deepseek\":\"React dominan 80% pasar. Ekosistem paling matang. Next.js, React Native, Remix — satu bahasa untuk semua platform. Pilihan rasional.\",\"big-pickle\":\"Vue 3 + Vite punya developer experience superior. Composition API setara React hooks, tapi lebih clean. Learning curve paling landai.\",\"claude\":\"Svelte adalah paradigm shift. No virtual DOM, compile-time optimization. Bundle size terkecil, runtime tercepat. Masa depan frontend mungkin no framework sama sekali.\"},\n      {\"deepseek\":\"React bukan cuma library, tapi standar industri. Cari developer React gampang. Cari Svelte developer? Susah. Business decision.\",\"big-pickle\":\"Vue dipakai di Alibaba, Xiaomi, GitLab. Ekosistem enterprise kuat. Documentation terbaik di kelasnya. Developer Vue lebih loyal.\",\"claude\":\"Framework war itu distraction. Yang penting: tim bisa deliver value. Pilih yang tim suka, karena happy team = quality code. Saya pilih Svelte personally.\"},\n      {\"deepseek\":\"Job market speaks. 10 lowongan React banding 1 Vue banding 0.1 Svelte. Untuk karir jangka panjang, React adalah safe bet.\",\"big-pickle\":\"Vue 3 performa sama dengan React 18 di benchmark. Tapi bundle size lebih kecil, memory usage lebih rendah. Efisien.\",\"claude\":\"Metriknya salah. Bukan popularitas, tapi happiness. State of JS survey: Svelte #1 most loved 3 tahun berturut-turut. Developer yang bahagia produce better code.\"}\n    ]}'\n)\n\n# ============================================================\n# FUNGSI HELP\n# ============================================================\nif [ \"$1\" = \"--help\" ] || [ \"$1\" = \"-h\" ]; then\n  echo \"  Panel diskusi 3 model AI dengan kepribadian berbeda.\"\n  echo \"\"\n  echo \"  Topik tersedia:\"\n  echo \"    1. ai-ganti-programmer   🤖  AI akan menggantikan programmer\"\n  echo \"    2. open-vs-closed        🔓  Open Source vs Closed Source AI\"\n  echo \"    3. frontend-framework    🖥️  React vs Vue vs Svelte\"\n  echo \"\"\n  echo \"  Contoh: bash demo-panel-ai.sh ai-ganti-programmer\"\n  echo \"\"\n  exit 0\nfi\n\n# ============================================================\n# PILIH TOPIK\n# ============================================================\nTOPIC_KEY=\"${1:-ai-ganti-programmer}\"\ncase \"$TOPIC_KEY\" in\n  ai-ganti-programmer) TOPIC_JSON=\"${TOPICS[0]}\" ;;\n  open-vs-closed)      TOPIC_JSON=\"${TOPICS[1]}\" ;;\n  frontend-framework)  TOPIC_JSON=\"${TOPICS[2]}\" ;;\n  *)\n    echo \"❌ Topik '$TOPIC_KEY' tidak dikenal.\"\n    echo \"   bash demo-panel-ai.sh --help\"\n    exit 1\n    ;;\nesac\n\nTOPIC=$(    echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['topic'])\")\nEMOJI=$(    echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['emoji'])\")\nSIDE0=$(    echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['sides'][0])\")\nSIDE1=$(    echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['sides'][1])\")\nSIDE2=$(    echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['sides'][2])\")\nROUNDS=$(   echo \"$TOPIC_JSON\" | python3 -c \"import json,sys; print(len(json.load(sys.stdin)['rounds']))\")\n\nM0_ID=$(  echo \"${MODELS[0]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['id'])\")\nM0_NAME=$(echo \"${MODELS[0]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['name'])\")\nM0_EMOJI=$(echo \"${MODELS[0]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['emoji'])\")\nM0_STYLE=$(echo \"${MODELS[0]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['style'])\")\n\nM1_ID=$(  echo \"${MODELS[1]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['id'])\")\nM1_NAME=$(echo \"${MODELS[1]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['name'])\")\nM1_EMOJI=$(echo \"${MODELS[1]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['emoji'])\")\nM1_STYLE=$(echo \"${MODELS[1]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['style'])\")\n\nM2_ID=$(  echo \"${MODELS[2]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['id'])\")\nM2_NAME=$(echo \"${MODELS[2]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['name'])\")\nM2_EMOJI=$(echo \"${MODELS[2]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['emoji'])\")\nM2_STYLE=$(echo \"${MODELS[2]}\" | python3 -c \"import json,sys; print(json.load(sys.stdin)['style'])\")\n\n# ============================================================\n# KIRIM PESAN KE INBOX\n# ============================================================\nsend_msg() {\n  local from=\"$1\" to=\"$2\" msg=\"$3\"\n  local time=$(date -u +\"%Y-%m-%dT%H:%M:%S.000Z\")\n  python3 -c \"\nimport json, os\nmsg = {'from': '$from', 'to': '$to', 'type': 'result', 'message': $(printf '%s' \"$msg\" | python3 -c \"import json,sys; print(json.dumps(sys.stdin.read()))\"), 'time': '$time', 'taskId': '$PANEL_ID', 'read': False}\nf = '$INBOX_FILE'\nd = json.